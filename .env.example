# ══════════════════════════════════════════════════════════════════
# HOMELAB DUAL — Variables de entorno
# Copiar este archivo a .env y rellenar los valores reales
# NUNCA subir el archivo .env a Git
# ══════════════════════════════════════════════════════════════════

# ─── AdGuard Home ─────────────────────────────────────────────────
ADGUARD_USER=admin
ADGUARD_PASSWORD=cambia_esta_password

# ─── Grafana ──────────────────────────────────────────────────────
GRAFANA_PASSWORD=cambia_esta_password

# ─── Vaultwarden ──────────────────────────────────────────────────
# Generar con: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=cambia_este_token
VAULTWARDEN_DOMAIN=https://vault.TU-DOMINIO

# ─── ntfy ─────────────────────────────────────────────────────────
NTFY_BASE_URL=http://TU-IP:8083

# ─── n8n ──────────────────────────────────────────────────────────
N8N_HOST=n8n.TU-DOMINIO
N8N_WEBHOOK_URL=https://n8n.TU-DOMINIO/

# ─── Pi-hole ──────────────────────────────────────────────────────
PIHOLE_PASSWORD=cambia_esta_password

# ─── IPs de red ───────────────────────────────────────────────────
# Sustituir por las IPs reales de tu red local
IP_HOMELAB_PRINCIPAL=192.168.1.X
IP_HOMELAB_SECUNDARIO=192.168.1.X
IP_PC_WINDOWS=192.168.1.X

# ─── Tailscale ────────────────────────────────────────────────────
# IPs Tailscale (100.x.x.x) asignadas a cada dispositivo
TAILSCALE_IP_PRINCIPAL=100.X.X.X
TAILSCALE_IP_SECUNDARIO=100.X.X.X
